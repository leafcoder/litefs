#!/usr/bin/env python
# coding: utf-8

"""
辅助函数

提供可复用的工具函数
"""

from datetime import datetime


def format_date(dt=None):
    """
    格式化日期
    
    Args:
        dt: datetime 对象，默认为当前时间
    
    Returns:
        格式化后的日期字符串
    """
    if dt is None:
        dt = datetime.now()
    
    return dt.strftime("%Y-%m-%d %H:%M:%S")


def sanitize_html(html):
    """
    清理 HTML，防止 XSS 攻击
    
    Args:
        html: HTML 字符串
    
    Returns:
        清理后的 HTML 字符串
    """
    if not html:
        return ""
    
    # 简单的 HTML 清理
    html = html.replace("<script", "&lt;script")
    html = html.replace("</script>", "&lt;/script&gt;")
    html = html.replace("javascript:", "javascript_disabled:")
    
    return html


def generate_pagination(total, current, per_page=10):
    """
    生成分页信息
    
    Args:
        total: 总数
        current: 当前页码
        per_page: 每页数量
    
    Returns:
        分页信息字典
    """
    total_pages = (total + per_page - 1) // per_page
    
    return {
        'total': total,
        'current': current,
        'per_page': per_page,
        'total_pages': total_pages,
        'has_prev': current > 1,
        'has_next': current < total_pages,
        'prev_page': current - 1 if current > 1 else None,
        'next_page': current + 1 if current < total_pages else None,
    }
