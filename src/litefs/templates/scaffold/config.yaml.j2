# Litefs 配置文件

# 服务器配置
host: "0.0.0.0"
port: 9090

# Web 根目录
webroot: "./site"

# 模板目录
template_dir: "./templates"

# 调试模式
debug: false

# 日志配置
log_level: "INFO"
log_file: "app.log"

# 监听队列大小
listen: 1024

# 最大请求大小
max_request_size: 10485760

# 最大上传大小
max_upload_size: 52428800

# 支持多个默认页面，按优先级顺序查找
# 优先查找 .py 文件，然后查找静态文件
default_page: "index,index.html"

# CORS 配置
cors:
  allow_origins: ["*"]
  allow_methods: ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
  allow_headers: ["Content-Type", "Authorization"]
  allow_credentials: false
  max_age: 3600

# 健康检查配置
health_check:
  path: "/health"
  ready_path: "/health/ready"
