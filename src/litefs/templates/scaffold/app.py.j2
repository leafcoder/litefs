#!/usr/bin/env python
# coding: utf-8

"""
${project_name} - Litefs 应用
"""

import sys
import os
from pathlib import Path

# 添加项目根目录到 Python 路径，以便导入 apps 和 config 模块
project_root = Path(__file__).parent
sys.path.insert(0, str(project_root))

from litefs import Litefs
from litefs.middleware import (
    CORSMiddleware,
    LoggingMiddleware,
    SecurityMiddleware,
    HealthCheck,
)
from litefs.config import load_config


def create_app():
    """
    创建应用实例
    
    Returns:
        Litefs 应用实例
    """
    config = load_config(config_file="config.yaml")
    
    litefs = (
        Litefs(**config.to_dict())
        .add_middleware(LoggingMiddleware)
        .add_middleware(SecurityMiddleware)
        .add_middleware(CORSMiddleware)
        .add_middleware(HealthCheck)
    )
    
    return litefs


if __name__ == "__main__":
    app = create_app()
    app.run()
