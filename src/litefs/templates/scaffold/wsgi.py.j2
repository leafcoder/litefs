#!/usr/bin/env python
# coding: utf-8

import litefs
from litefs import Litefs
from litefs.middleware import (
    CORSMiddleware,
    LoggingMiddleware,
    SecurityMiddleware,
    HealthCheck,
)

# 配置 Litefs 应用
app = (
    Litefs(config_file="config.yaml")
    .add_middleware(LoggingMiddleware)
    .add_middleware(SecurityMiddleware)
    .add_middleware(CORSMiddleware)
    .add_middleware(HealthCheck)
)

# 挂载静态文件目录
app.add_static('/static', 'static')

# 定义默认首页处理函数
def index_handler(request):
    """
    处理首页请求
    
    Args:
        request: 请求对象
        
    Returns:
        str: 响应内容
    """
    request.start_response(200, [("Content-Type", "text/html; charset=utf-8")])
    with open('templates/index.html', 'r', encoding='utf-8') as f:
        content = f.read().replace('${project_name}', '${project_name}')
    return content


# 定义关于页面处理函数
def about_handler(request):
    """
    处理关于页面请求
    
    Args:
        request: 请求对象
        
    Returns:
        str: 响应内容
    """
    request.start_response(200, [("Content-Type", "text/html; charset=utf-8")])
    with open('templates/about.html', 'r', encoding='utf-8') as f:
        content = f.read().replace('${project_name}', '${project_name}')
    return content


# 定义 API 接口处理函数
def api_handler(request):
    """
    处理 API 请求
    
    Args:
        request: 请求对象
        
    Returns:
        str: 响应内容
    """
    request.start_response(200, [("Content-Type", "application/json; charset=utf-8")])
    import json
    return json.dumps({
        "name": "${project_name}",
        "version": "1.0.0",
        "status": "ok",
        "message": "Welcome to the API!"
    }, ensure_ascii=False)


# 添加路由
app.add_get('/', index_handler, name='index')
app.add_get('/about', about_handler, name='about')
app.add_get('/api', api_handler, name='api')

# 获取 WSGI application callable
application = app.wsgi()

# 打印启动信息
print("=" * 60)
print("Litefs WSGI Application")
print("=" * 60)
print("Version:", litefs.__version__)
print("Debug:", app.config.debug)
print("=" * 60)
